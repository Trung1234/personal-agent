<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aiagent.mapper.TaskMapper">

    <insert id="insert" parameterType="com.aiagent.model.Task"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO Tasks (user_id, description, status, created_at, updated_at)
        VALUES (#{userId}, #{description}, #{status}, GETDATE(), GETDATE())
    </insert>

    <select id="findById" resultType="com.aiagent.model.Task">
        SELECT * FROM Tasks WHERE id = #{id}
    </select>

</mapper>